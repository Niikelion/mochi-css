{
    "$schema": "https://v2-8-12.turborepo.dev/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [ "^build" ],
            "outputs": [ "dist/**" ]
        },
        "@mochi-css/benchmarks#codegen": {
            "inputs": [
                "codegen/**",
                "implementations/mochi-vanilla-react/src/**"
            ],
            "outputs": [
                "implementations/stitches/src/**",
                "implementations/mochi-stitches/src/**",
                "implementations/vanilla-extract/src/**",
                "implementations/panda/src/**",
                "implementations/panda/panda.config.ts",
                "implementations/css-modules/src/**"
            ]
        },
        "@mochi-css/benchmark-stitches#build": {
            "dependsOn": [ "@mochi-css/benchmarks#codegen" ]
        },
        "@mochi-css/benchmark-mochi-stitches#build": {
            "dependsOn": [ "@mochi-css/benchmarks#codegen" ]
        },
        "@mochi-css/benchmark-vanilla-extract#build": {
            "dependsOn": [ "@mochi-css/benchmarks#codegen" ]
        },
        "@mochi-css/benchmark-panda#build": {
            "dependsOn": [ "@mochi-css/benchmarks#codegen" ]
        },
        "@mochi-css/benchmark-css-modules#build": {
            "dependsOn": [ "@mochi-css/benchmarks#codegen" ]
        },
        "test": {},
        "coverage": {},
        "dev": {
            "persistent": true,
            "cache": false
        },
        "format": {
            "cache": false
        },
        "lint": {},
        "lint:fix": {
            "cache": false
        }
    }
}
