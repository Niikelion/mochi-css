{
    "$schema": "https://v2-8-12.turborepo.dev/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [ "^build" ],
            "outputs": [ "dist/**" ]
        },
        "build-example": {
            "dependsOn": [ "^build-example" ],
            "outputs": [ "dist/**" ]
        },
        "test": {},
        "coverage": {},
        "dev": {
            "persistent": true,
            "cache": false
        },
        "format": {
            "cache": false
        },
        "format:check": {},
        "lint": {},
        "lint:fix": {
            "cache": false
        }
    }
}
