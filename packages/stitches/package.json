{
    "name": "@mochi-css/stitches",
    "repository": "git@github.com:Niikelion/mochi-css.git",
    "version": "0.1.4",
    "license": "MIT",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
        "/dist"
    ],
    "typesVersions": {
        "*": {
            "config": [
                "./dist/config/index.d.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "import": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "require": "./dist/index.js"
            }
        },
        "./config": {
            "import": {
                "types": "./dist/config/index.d.mts",
                "import": "./dist/config/index.mjs"
            },
            "require": {
                "types": "./dist/config/index.d.ts",
                "require": "./dist/config/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsc --noEmit && tsdown",
        "test": "vitest",
        "coverage": "vitest run --coverage",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@mochi-css/core": "^5.0.0",
        "@mochi-css/vanilla": "^5.0.0",
        "clsx": "^2.1.1"
    },
    "peerDependencies": {
        "@mochi-css/builder": "^5.0.0",
        "@mochi-css/config": "^5.0.0",
        "@mochi-css/plugins": "^5.0.0",
        "@swc/core": "^1",
        "react": "^19"
    },
    "peerDependenciesMeta": {
        "@mochi-css/builder": {
            "optional": true
        },
        "@mochi-css/config": {
            "optional": true
        },
        "@mochi-css/plugins": {
            "optional": true
        },
        "@swc/core": {
            "optional": true
        }
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@eslint/js": "^9.18.0",
        "@gamedev-sensei/ts-config": "^2.1.0",
        "@gamedev-sensei/tsdown-config": "^2.1.0",
        "@mochi-css/builder": "^5.0.0",
        "@mochi-css/config": "*",
        "@mochi-css/plugins": "^5.0.0",
        "@mochi-css/shared-config": "^2.0.0",
        "@swc/types": "^0.1.25",
        "@types/node": "^24.8.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^4.0.15",
        "eslint": "^9",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "happy-dom": "^20.8.9",
        "prettier": "^3.8.1",
        "react": "^19",
        "react-dom": "^19.2.4",
        "tsdown": "^0.15.7",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.21.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^4.0.15"
    }
}
