{
    "name": "@mochi-css/vanilla",
    "repository": "git@github.com:Niikelion/mochi-css.git",
    "version": "6.0.0",
    "license": "MIT",
    "keywords": [
        "css-in-js",
        "styling",
        "styles",
        "react"
    ],
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
        "/dist"
    ],
    "typesVersions": {
        "*": {
            "config": [
                "./dist/config/index.d.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "import": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "require": "./dist/index.js"
            }
        },
        "./config": {
            "import": {
                "types": "./dist/config/index.d.mts",
                "import": "./dist/config/index.mjs"
            },
            "require": {
                "types": "./dist/config/index.d.ts",
                "require": "./dist/config/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsc --noEmit && tsdown",
        "test": "vitest",
        "coverage": "vitest run --coverage",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@mochi-css/builder": "^6.0.0",
        "@mochi-css/config": "^6.0.0",
        "@mochi-css/plugins": "^6.0.0",
        "@mochi-css/shared-config": "^2.0.0",
        "@mochi-css/test": "^2.0.0",
        "@swc/core": "^1.15.13",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/css-tree": "^2.3.10",
        "@types/node": "^24.8.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.3",
        "@webref/css": "^8.2.3",
        "css-tree": "^3.1.0",
        "dedent": "^1.7.1",
        "eslint": "^9.39.2",
        "happy-dom": "^20.8.9",
        "prettier": "^3.8.1",
        "react": "^19",
        "react-dom": "^19.2.4",
        "typescript": "^5.9.3",
        "vitest": "^4.0.15"
    },
    "dependencies": {
        "@mochi-css/core": "^6.0.0",
        "clsx": "^2.1.1",
        "csstype": "^3.2.3"
    },
    "peerDependencies": {
        "@mochi-css/builder": "^6.0.0",
        "@mochi-css/config": "^6.0.0",
        "@mochi-css/plugins": "^6.0.0",
        "@swc/core": "^1"
    },
    "peerDependenciesMeta": {
        "@mochi-css/builder": {
            "optional": true
        },
        "@mochi-css/config": {
            "optional": true
        },
        "@mochi-css/plugins": {
            "optional": true
        },
        "@swc/core": {
            "optional": true
        }
    }
}
