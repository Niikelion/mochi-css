{
    "name": "@mochi-css/next",
    "repository": "git@github.com:Niikelion/mochi-css.git",
    "version": "2.0.1",
    "license": "MIT",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
        "/dist"
    ],
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "import": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "require": "./dist/index.js"
            }
        },
        "./loader": {
            "import": {
                "types": "./dist/loader.d.mts",
                "import": "./dist/loader.mjs"
            },
            "require": {
                "types": "./dist/loader.d.ts",
                "require": "./dist/loader.js"
            }
        }
    },
    "scripts": {
        "build": "tsc --noEmit && tsdown",
        "test": "vitest",
        "coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@mochi-css/builder": "^2.1.0",
        "@mochi-css/config": "^2.1.0"
    },
    "devDependencies": {
        "@mochi-css/shared-config": "^1.0.0",
        "@mochi-css/test": "^1.0.0",
        "@types/node": "^24.8.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.15"
    },
    "peerDependencies": {
        "next": "^14 || ^15 || ^16"
    }
}
